{
  "manifest_version": "1.0",
  "skill_id": "python-lint-fix",
  "name": "Python Lint Fix",
  "version": "1.0.0",
  "description": "One-shot auto-fix and formatting for Python (Ruff) and Markdown (mdformat, markdownlint).",
  "author": "kimcharli",
  "license": "MIT",
  "homepage": "https://github.com/kimcharli/ck-skills",
  "repository": {
    "type": "git",
    "url": "https://github.com/kimcharli/ck-skills.git"
  },
  "keywords": [
    "lint",
    "format",
    "python",
    "ruff",
    "markdown",
    "mdformat",
    "markdownlint",
    "productivity"
  ],
  "categories": [
    "linting",
    "productivity",
    "workflow"
  ],
  "commands": [
    {
      "name": "lint",
      "description": "Fix, format, and verify Python and Markdown code",
      "file": "commands/lint.md"
    }
  ],
  "features": [
    "Python auto-fix and formatting with Ruff",
    "Markdown formatting with mdformat",
    "Markdown linting with markdownlint-cli",
    "Automated verification of clean state",
    "Bundled test execution (pytest)",
    "Environment detection (supports uv and native tools)"
  ],
  "dependencies": [],
  "documentation": {
    "readme": "README.md"
  },
  "installation": {
    "method": "script",
    "script": "install.sh",
    "uninstall_script": "uninstall.sh",
    "location": "~/.agents/skills/ck/lint"
  },
  "system_requirements": {
    "claude_code": "latest",
    "bash": "4.0+",
    "ruff": "latest",
    "mdformat": "latest",
    "npm": "for markdownlint-cli"
  },
  "permissions": {
    "file_read": true,
    "file_write": true,
    "file_delete": false,
    "bash_execution": true,
    "git_access": false
  },
  "created_at": "2026-03-18",
  "updated_at": "2026-03-18",
  "last_release": "2026-03-18"
